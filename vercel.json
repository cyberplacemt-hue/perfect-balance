{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install --frozen-lockfile && pnpm --filter @workspace/perfect-balance run build",
  "outputDirectory": "artifacts/perfect-balance/dist/public",
  "installCommand": "npm install -g pnpm && pnpm install --frozen-lockfile",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
